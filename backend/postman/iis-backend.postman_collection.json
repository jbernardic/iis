          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/xml/validate",
              "host": [ "{{baseUrl}}" ],
              "path": [ "api", "xml", "validate" ]
            },
            "description": "Validates the generated orders XML against order.xsd. Returns {\"valid\":true|false,\"messages\":[...]}. Requires READ or FULL."
          }
        }
      ]
    },
    {
